{
  "expo": {
    "name": "FlightRest",
    "slug": "flightrest",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "scheme": "flightrest",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flightrest.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.flightrest.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0f",
          "image": "./assets/icon.png",
          "imageWidth": 180
        }
      ],
      "expo-notifications"
    ],
    "updates": {
      "url": "https://u.expo.dev/83a02f40-d487-4c14-9013-01189c276304",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "83a02f40-d487-4c14-9013-01189c276304"
      },
      "privacyPolicyUrl": "https://rockygibson94-ux.github.io/flightrest/privacy-policy",
      "router": {
        "origin": false
      }
    }
  }
}
