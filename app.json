{
  "expo": {
    "name": "FlightRest",
    "slug": "flightrest",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flightrest.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "FlightRest uses your location to estimate drive time to the airport.",
        "NSUserNotificationsUsageDescription": "FlightRest needs notifications to deliver your wake-up alarm.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.flightrest.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_EXACT_ALARM"
      ]
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0f",
          "image": "./assets/icon.png",
          "imageWidth": 180
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4f8ef7"
        }
      ]
    ],
    "scheme": "flightrest",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "83a02f40-d487-4c14-9013-01189c276304"
      },
      "privacyPolicyUrl": "https://rockygibson94-ux.github.io/flightrest/privacy-policy",
      "router": {
        "origin": false
      }
    }
  }
}
